{
  "version": 2,
  "builds": [
    {
      "src": "api/claude.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/generate_pptx.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/claude",
      "dest": "api/claude.js"
    },
    {
      "src": "/api/generate-pptx",
      "dest": "api/generate_pptx.py"
    },
    {
      "src": "/(.*)",
      "dest": "public/$1"
    }
  ]
}